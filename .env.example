# ----- WhatsApp -----
# Numero do contato de destino em formato internacional, SO digitos.
# Ex.: Brasil DDI 55 + DDD 11 + numero 999998888  ->  5511999998888
WHATSAPP_TARGET=5511999998888

# Prefixo opcional adicionado em toda mensagem encaminhada
MESSAGE_PREFIX=[MeshCore]

# (Opcional) Caminho do Chrome/Edge ja instalado, para nao baixar o Chromium
# do puppeteer (que costuma ser bloqueado por antivirus no Windows).
# Se vazio, a app tenta autodetectar Chrome e depois Edge.
# Ex.: C:\Program Files\Google\Chrome\Application\chrome.exe
CHROME_PATH=

# ----- MeshCore (BLE) -----
# (Opcional) Nome anunciado pelo dispositivo MeshCore para filtrar a conexao.
# Deixe vazio para conectar ao primeiro dispositivo MeshCore que aparecer.
MESHCORE_DEVICE_NAME=

# (Opcional) MAC/UUID do periferico BLE para conectar direto sem varrer por nome.
MESHCORE_DEVICE_ID=

# Nome que esta ponte anuncia ao radio no login (CMD_APP_START)
APP_NAME=wa-bridge
